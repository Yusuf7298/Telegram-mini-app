generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  BOX_PURCHASE
  BOX_REWARD
  FREE_BOX
  REFERRAL
  VAULT_REWARD
  WELCOME_BONUS
}

model User {
  id                   String   @id @default(uuid())
  platformId           String   @unique
  username             String?
  freeBoxUsed          Boolean  @default(false)
  paidBoxesOpened      Int      @default(0)
  welcomeBonusUnlocked Boolean  @default(false)
  referredBy           String?
  referrals            Int      @default(0)
  createdAt            DateTime @default(now())

  wallet          Wallet?
  userVaults      UserVault[]
  transactions    Transaction[]
  boxOpens        BoxOpen[]
  idempotencyKeys IdempotencyKey[]
}

model Wallet {
  id           String  @id @default(uuid())
  userId       String  @unique
  cashBalance  Decimal @default(0) @db.Decimal(10, 2)
  bonusBalance Decimal @default(0) @db.Decimal(10, 2)

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  boxId         String?
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  meta          Json?
  user          User            @relation(fields: [userId], references: [id])
  box           Box?            @relation(fields: [boxId], references: [id])

  @@index([userId, createdAt])
}

model Box {
  id          String  @id @default(uuid())
  name        String
  price       Decimal @db.Decimal(10, 2)
  rewardTable Json?

  boxOpens     BoxOpen[]
  transactions Transaction[]
}

model BoxOpen {
  id           String   @id @default(uuid())
  userId       String
  boxId        String
  rewardAmount Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  box  Box  @relation(fields: [boxId], references: [id])

  @@index([userId, createdAt])
}

model Vault {
  id       String  @id @default(uuid())
  name     String
  target   Int
  reward   Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)

  userVaults UserVault[]
}

model UserVault {
  id       String  @id @default(uuid())
  userId   String
  vaultId  String
  progress Int     @default(0)
  claimed  Boolean @default(false)

  user  User  @relation(fields: [userId], references: [id])
  vault Vault @relation(fields: [vaultId], references: [id])

  @@unique([userId, vaultId])
  @@index([userId, claimed])
}

model IdempotencyKey {
  id           String   @id
  userId       String
  boxId        String
  rewardAmount Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
