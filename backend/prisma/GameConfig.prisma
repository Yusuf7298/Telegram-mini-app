model GameConfig {
    id          String @id @default("global")
    rtpModifier Float  @default(1)
    maxPayoutMultiplier  Decimal @default(1.2) @db.Decimal(10, 4)
    minRtpModifier       Decimal @default(1) @db.Decimal(10, 4)
    maxRtpModifier       Decimal @default(1.2) @db.Decimal(10, 4)
    referralRewardAmount Decimal @default(200) @db.Decimal(10, 2)
    freeBoxRewardAmount  Decimal @default(200) @db.Decimal(10, 2)
    minBoxReward         Int     @default(150)
    maxBoxReward         Int     @default(251)
    waitlistBonus        Int     @default(1000)
    maxPlaysPerDay       Int     @default(5)
    withdrawMinPlays     Int     @default(5)
    withdrawCooldownMs   Int     @default(60000)
    withdrawRiskThreshold Int    @default(70)
    maxReferralsPerIpPerDay Int  @default(5)
    waitlistRiskThreshold Int    @default(50)
    rapidOnboardingWindowMs Int  @default(10000)
    minPlayIntervalMs    Int     @default(300)
    referralWindowMs     Int     @default(86400000)
    dailyRewardTable     String  @default("[100,125,150,175,200,250,300]")
    dailyRewardBigWinThreshold Int @default(1000)
    winHistoryBigWinThreshold  Int @default(1000)
}
