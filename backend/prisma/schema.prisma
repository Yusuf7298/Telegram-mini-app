model BoxReward {
  id             String  @id @default(uuid())
  boxId          String
  reward         Decimal
  weight         Int
  category       String?
  label          String?
  isJackpot      Boolean @default(false)
  maxWinners     Int?
  currentWinners Int     @default(0)
  box Box @relation(fields: [boxId], references: [id])
  @@index([boxId])
  @@index([boxId, isJackpot])
}

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}
enum TransactionType {
  BOX_PURCHASE
  BOX_REWARD
  FREE_BOX
  REFERRAL
  VAULT_REWARD
  DAILY_REWARD
  WELCOME_BONUS
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ReferralStatus {
  PENDING
  JOINED
  ACTIVE
}

model User {
  id                   String   @id @default(uuid())
  telegramId           String?  @unique
  platformId           String   @unique
  username             String?
  firstName            String?
  lastName             String?
  profilePhotoUrl      String?
  role                 Role     @default(USER)
  referralCode         String   @unique
  referredById         String?
  deviceHash           String?
  createdIp            String   @default("unknown")
  lastLoginIp          String   @default("unknown")
  riskScore            Int      @default(0)
  waitlistBonusEligible Boolean @default(true)
  accountStatus        String   @default("ACTIVE")
  lastPlayTimestamp    DateTime?
  signupIp             String?
  signupDeviceId       String?
  referralCount        Int      @default(0)
  freeBoxUsed          Boolean  @default(false)
  paidBoxesOpened      Int      @default(0)
  totalPlaysCount      Int      @default(0)
  waitlistBonusGranted Boolean  @default(false)
  waitlistBonusUnlocked Boolean @default(false)
  welcomeBonusUnlocked Boolean  @default(false)
  dailyRewardStreak     Int      @default(0)
  lastDailyRewardClaimAt DateTime?
  createdAt            DateTime @default(now())
  referralStatus       ReferralStatus @default(PENDING)
  referralJoinedAt     DateTime?
  referralActivatedAt  DateTime?
  isFrozen              Boolean @default(false)
  wallet          Wallet?
  userVaults      UserVault[]
  transactions    Transaction[]
  boxOpens        BoxOpen[]
  boxOpenLogs     BoxOpenLog[]
  idempotencyKeys IdempotencyKey[]
  bonusUsages    BonusUsage[]
  referralLogs   ReferralLog[]         @relation("UserReferralLogs")
  referredLogs   ReferralLog[]         @relation("UserReferredLogs")
  suspiciousLogs SuspiciousActionLog[]
  auditLogs      AuditLog[]
  rewardRevokes  RewardRevocation[]
  referralRewardGrantsGiven ReferralRewardGrant[] @relation("ReferralRewardGrantsGiven")
  referralRewardGrantReceived ReferralRewardGrant? @relation("ReferralRewardGrantReceived")
  referredBy User?  @relation("UserReferredBy", fields: [referredById], references: [id])
  referrals  User[] @relation("UserReferredBy")
  @@index([createdIp])
  @@index([deviceHash])
  @@index([riskScore])
}

model Wallet {
  id           String  @id @default(uuid())
  userId       String  @unique
  cashBalance  Decimal @default(0) @db.Decimal(10, 2)
  bonusBalance Decimal @default(0) @db.Decimal(10, 2)
  bonusLocked Boolean @default(false)
  user User @relation(fields: [userId], references: [id])
  // DB-level non-negative balance constraints should be enforced via a migration or manual SQL, not Prisma schema.
}

model Transaction {
  id            String          @id @default(uuid())
  userId        String
  boxId         String?
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  meta          Json?
  user          User            @relation(fields: [userId], references: [id])
  box           Box?            @relation(fields: [boxId], references: [id])
  @@index([userId, createdAt])
}

model Box {
  id          String  @id @default(uuid())
  name        String
  price       Decimal @db.Decimal(10, 2)
  rewardTable Json?
  boxOpens     BoxOpen[]
  transactions Transaction[]
  boxRewards   BoxReward[]
}

model BoxOpen {
  id           String   @id @default(uuid())
  userId       String
  boxId        String
  rewardAmount Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  box  Box  @relation(fields: [boxId], references: [id])
  @@index([userId, createdAt])
}

model Vault {
  id       String  @id @default(uuid())
  name     String
  target   Int
  reward   Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  userVaults UserVault[]
}

model UserVault {
  id       String  @id @default(uuid())
  userId   String
  vaultId  String
  progress Int     @default(0)
  claimed  Boolean @default(false)
  user  User  @relation(fields: [userId], references: [id])
  vault Vault @relation(fields: [vaultId], references: [id])
  @@unique([userId, vaultId])
  @@index([userId, claimed])
}

model IdempotencyKey {
  id           String   @id
  userId       String
  boxId        String
  rewardAmount Decimal  @db.Decimal(10, 2)
  response     Json?
  createdAt    DateTime @default(now())
  action    String
  status    String    @default("pending")
  expiresAt DateTime?
  user User @relation(fields: [userId], references: [id])
  @@index([userId])
}

model ReferralLog {
  id         String   @id @default(uuid())
  referrerId String
  referredId String
  ip         String
  deviceId   String?
  createdAt  DateTime @default(now())
  suspicious Boolean  @default(false)

  referrer User @relation("UserReferralLogs", fields: [referrerId], references: [id])
  referred User @relation("UserReferredLogs", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@index([ip])
  @@index([deviceId])
}

model ReferralRewardGrant {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String   @unique
  amount         Decimal  @db.Decimal(10, 2)
  sourceAction   String
  createdAt      DateTime @default(now())

  referrer User @relation("ReferralRewardGrantsGiven", fields: [referrerId], references: [id])
  referred User @relation("ReferralRewardGrantReceived", fields: [referredUserId], references: [id])

  @@index([referrerId, createdAt])
}

model BoxOpenLog {
  id         String   @id @default(uuid())
  userId     String
  ip         String
  deviceId   String?
  action     String
  createdAt  DateTime @default(now())
  suspicious Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model BonusUsage {
  id        String   @id @default(uuid())
  userId    String
  bonusType String
  amount    Decimal  @db.Decimal(10, 2)
  usedAt    DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}

model SuspiciousActionLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  flaggedAt DateTime @default(now())
  reviewed  Boolean  @default(false)
  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RewardRevocation {
  id        String   @id @default(uuid())
  userId    String
  rewardId  String
  revokedAt DateTime @default(now())
  reason    String?

  user User @relation(fields: [userId], references: [id])
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  data      Json?
  createdAt DateTime @default(now())
}

model SystemStats {
  id               String  @id @default("global")
  totalIn          Decimal @default(0)
  totalOut         Decimal @default(0)
  totalBoxesOpened Int     @default(0)
  jackpotWins      Int     @default(0)
}

model GameConfig {
  id                   String  @id @default("global")
  rtpModifier          Float   @default(1)
  maxPayoutMultiplier  Decimal @default(1.2) @db.Decimal(10, 4)
  minRtpModifier       Decimal @default(1) @db.Decimal(10, 4)
  maxRtpModifier       Decimal @default(1.2) @db.Decimal(10, 4)
  referralRewardAmount Decimal @default(200) @db.Decimal(10, 2)
  freeBoxRewardAmount  Decimal @default(200) @db.Decimal(10, 2)
  minBoxReward         Int     @default(150)
  maxBoxReward         Int     @default(251)
  waitlistBonus        Int     @default(1000)
  maxPlaysPerDay       Int     @default(5)
  withdrawMinPlays     Int     @default(5)
  withdrawCooldownMs   Int     @default(60000)
  withdrawRiskThreshold Int    @default(70)
  maxReferralsPerIpPerDay Int  @default(5)
  waitlistRiskThreshold Int    @default(50)
  rapidOnboardingWindowMs Int  @default(10000)
  minPlayIntervalMs    Int     @default(300)
  referralWindowMs     Int     @default(86400000)
  dailyRewardTable     String  @default("[100,125,150,175,200,250,300]")
  dailyRewardBigWinThreshold Int @default(1000)
  winHistoryBigWinThreshold  Int @default(1000)
}

model TelegramAuthLog {
  hash      String   @id
  createdAt DateTime @default(now())
}
